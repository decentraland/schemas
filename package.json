{
  "version": "0.0.0",
  "name": "@dcl/schemas",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dapps": {
      "types": "./dist/dapps/index.d.ts",
      "default": "./dist/dapps/index.js"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "default": "./dist/platform/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./misc": {
      "types": "./dist/misc/index.d.ts",
      "default": "./dist/misc/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    },
    "./validation/types": {
      "types": "./dist/validation/types.d.ts",
      "default": "./dist/validation/types.js"
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "test": "mocha",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "check-api": "npm run build && api-extractor run --typescript-compiler-folder ./node_modules/typescript",
    "refresh-api": "npm run build && api-extractor run --local --verbose --diagnostics --typescript-compiler-folder ./node_modules/typescript"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decentraland/schemas.git"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none",
    "tabWidth": 2
  },
  "devDependencies": {
    "@dcl/eslint-config": "^1.1.1",
    "@microsoft/api-extractor": "^7.34.8",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.0.0",
    "@types/sinon": "^10.0.14",
    "ajv": "^8.11.0",
    "ajv-errors": "^3.0.0",
    "ajv-keywords": "^5.1.0",
    "expect": "^29.5.0",
    "mitt": "^3.0.1",
    "mocha": "^10.2.0",
    "sinon": "^15.0.4",
    "ts-node": "^10.9.1",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "ajv": "^8.11.0",
    "ajv-errors": "^3.0.0",
    "ajv-keywords": "^5.1.0"
  },
  "peerDependenciesMeta": {
    "ajv": { "optional": true },
    "ajv-errors": { "optional": true },
    "ajv-keywords": { "optional": true }
  },
  "files": [
    "dist"
  ]
}
